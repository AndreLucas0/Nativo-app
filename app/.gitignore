# Spring Boot Application .gitignore
# This file is specific to the /app directory

### Maven ###
target/
!**/src/main/**/target/
!**/src/test/**/target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties

### Spring Boot ###
HELP.md
spring-boot-starter-parent/

### STS (Spring Tool Suite) ###
.apt_generated
.apt_generated_test
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

### Java ###
*.class
*.jar
!.mvn/wrapper/maven-wrapper.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*

### Application Specific ###
application-local.properties
application-local.yml
application-secrets.properties
application-secrets.yml

### H2 Database (for local development) ###
*.h2.db
*.mv.db
*.trace.db

### Test Coverage ###
.coverage
.pytest_cache/
.hypothesis/

### Gradle (if migrated in future) ###
.gradle
gradle-app.setting
!gradle-wrapper.jar
.gradletasknamecache

